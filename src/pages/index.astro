---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>agasthya.dev</h1>
			<p>
				Notes on backend systems, cloud architecture, and engineering decisions
				in B2B SaaS &mdash; the unglamorous middle layer where most production
				incidents and most real wins happen.
			</p>
			<p>
				Read the latest on the <a href="/blog">blog</a>, or learn more
				<a href="/about">about this site</a>.
			</p>
			<p>
				Available for selected consulting engagements:
				<a href="mailto:hello@agasthya.dev">hello@agasthya.dev</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
